{
  "name": "veggies",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "CC-BY-NC-ND-4.0",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build --mode staging",
    "build:ci": "npm run type-check && vite build --mode ci",
    "build:production": "npm run type-check && vite build --base=/",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "type-check": "vue-tsc --build --noEmit",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@fontsource/bungee-shade": "5.2.7",
    "@fontsource/nunito": "5.2.7",
    "@mdi/js": "7.4.47",
    "@vueuse/core": "14.3.0",
    "canvas-confetti": "1.9.4",
    "chart.js": "4.5.1",
    "chartjs-chart-matrix": "3.0.4",
    "chartjs-plugin-annotation": "3.1.0",
    "chartjs-plugin-datalabels": "2.2.0",
    "eventsource-parser": "3.1.0",
    "pinia": "3.0.4",
    "reka-ui": "2.9.8",
    "remeda": "2.37.0",
    "simple-icons": "16.21.0",
    "tailwind-variants": "3.2.2",
    "temporal-polyfill-lite": "0.4.0",
    "vue": "3.5.35",
    "vue-chartjs": "5.3.3",
    "vue-i18n": "11.4.4",
    "vue-router": "5.1.0",
    "vue-tippy": "6.7.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@pinia/testing": "1.0.3",
    "@playwright/test": "1.60.0",
    "@tsconfig/node24": "24.0.4",
    "@types/canvas-confetti": "1.9.0",
    "@types/jsdom": "28.0.3",
    "@types/node": "25.9.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-istanbul": "3.2.6",
    "@vitest/eslint-plugin": "1.6.18",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.10",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "canvas": "3.2.3",
    "eslint": "10.4.1",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-vue": "10.9.1",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "jsdom": "29.1.1",
    "patch-package": "8.0.1",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "resize-observer-polyfill": "1.5.1",
    "tailwindcss": "3.4.19",
    "typescript": "6.0.3",
    "unplugin-vue-components": "32.1.0",
    "vite": "7.3.3",
    "vite-plugin-pwa": "1.3.0",
    "vite-plugin-vue-devtools": "8.1.2",
    "vitest": "3.2.6",
    "vue-tsc": "3.3.3"
  },
  "engines": {
    "node": ">= 24.11.0"
  },
  "postcss": {
    "plugins": {
      "tailwindcss/nesting": {},
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "allowScripts": {
    "vue-demi@0.14.10": true,
    "canvas@3.2.3": true,
    "esbuild@0.27.2": true
  }
}
